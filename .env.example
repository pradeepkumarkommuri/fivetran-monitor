# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# Fivetran (required)
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
FIVETRAN_API_KEY=your_api_key
FIVETRAN_API_SECRET=your_api_secret

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# ntfy.sh
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
NTFY_TOPIC=fivetran-alerts
NTFY_SERVER=https://ntfy.sh
NTFY_ACCESS_TOKEN=

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# Email / Office 365
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
EMAIL_ENABLED=true
SMTP_HOST=smtp.office365.com
SMTP_PORT=587
EMAIL_USE_TLS=true
SMTP_USERNAME=you@yourcompany.com
SMTP_PASSWORD=your_app_password
EMAIL_FROM=you@yourcompany.com
EMAIL_TO=alerts@yourcompany.com

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# Database
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
DATABASE_URL=postgresql+psycopg2://monitor:monitor@postgres:5432/fivetran_monitor

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# MinIO / Object Storage
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
MINIO_ENDPOINT=http://minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=fivetran-monitor

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# Spark (Kubernetes)
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
SPARK_MASTER=k8s://https://kubernetes.default.svc:443
SPARK_IMAGE=your-registry/fivetran-monitor-spark:latest
SPARK_EXECUTOR_INSTANCES=2
SPARK_EXECUTOR_MEMORY=2g

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# ML
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
ML_ANOMALY_CONTAMINATION=0.05
ML_ANOMALY_N_ESTIMATORS=100
ML_ANOMALY_THRESHOLD=-0.1
ML_FORECAST_HORIZON_HOURS=24
ML_FORECAST_INTERVAL_WIDTH=0.95
ML_TRAINING_LOOKBACK_DAYS=90
ML_MIN_TRAINING_SAMPLES=30
ML_RETRAIN_EVERY_HOURS=24

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# Alert thresholds
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
DROP_THRESHOLD_PCT=20
SPIKE_THRESHOLD_PCT=200
ZERO_ROWS_ALERT=true
DELAY_MULTIPLIER=2.0
ALERT_DEDUP_WINDOW_MINUTES=60

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# Scheduler
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
SCHEDULE_INTERVAL_MINUTES=60
SCHEDULE_RUN_ON_START=true
APP_ENV=production
